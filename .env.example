# MongoDB Atlas Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/yapp-chat?retryWrites=true&w=majority&ssl=true
VITE_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/yapp-chat?retryWrites=true&w=majority&ssl=true
VITE_MONGODB_DATABASE=yapp-chat
MONGODB_DATABASE=yapp-chat

# Clerk Configuration
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Zego Configuration
VITE_ZEGO_APP_ID=your_app_id
VITE_ZEGO_SERVER_SECRET=your_server_secret

# Server Configuration
VITE_SERVER_URL=https://your-app-name.herokuapp.com

# Supabase Configuration (for webhook integration)
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Node Environment
NODE_ENV=production
PORT=3001
